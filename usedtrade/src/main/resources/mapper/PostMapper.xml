<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper 
   PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" 
   "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.pknu26.studygroup.mapper.UserSocialAccountMapper">
    
    <insert id="insertPost" parameterType="PostDTO" useGeneratedKeys="true" keyProperty="postId" keyColumn="post_id">
        INSERT INTO posts (
            user_id, 
            board_id, 
            title, 
            content_posts, 
            price, 
            category, 
            location, 
            status
        ) VALUES (
            #{userId}, 
            #{boardId}, 
            #{title}, 
            #{content}, 
            #{price}, 
            #{category}, 
            #{location}, 
            'SELLING'
        )
    </insert>

</mapper>