<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.pknu26.usedtrade.mapper.UserMapper">

    <select id="findByLoginId" resultType="com.pknu26.usedtrade.dto.UserDto">
        SELECT 
            user_id AS userId,
            login_id AS loginId,
            password,
            nickname,
            user_name AS userName
        FROM users 
        WHERE login_id = #{loginId}
    </select>

</mapper>